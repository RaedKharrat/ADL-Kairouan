{
    "version": 3,
    "caseSensitive": false,
    "basePath": "",
    "rewrites": {
        "beforeFiles": [],
        "afterFiles": [
            {
                "source": "/api/:path*",
                "destination": "https://adl-kairouan-backend.onrender.com/api/v1/:path*",
                "regex": "^\\/api(?:\\/((?:[^\\/]+?)(?:\\/(?:[^\\/]+?))*))?(?:\\/)?$",
                "check": true
            }
        ],
        "fallback": []
    },
    "redirects": [
        {
            "source": "/:path+/",
            "destination": "/:path+",
            "permanent": true,
            "internal": true,
            "regex": "^(?:\\/((?:[^\\/]+?)(?:\\/(?:[^\\/]+?))*))\\/$"
        }
    ],
    "headers": []
}